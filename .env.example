# ---------------------------------------------------------------------------
# Database (PostgreSQL — Neon / Supabase / local)
# Neon example: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/workflow_dev?schema=public"

# ---------------------------------------------------------------------------
# Auth — used to sign the admin session JWT (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
AUTH_SECRET="change-me-to-a-long-random-string"
# Legacy public URL (kept for backwards compatibility).
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Public site URL — used for canonical links, sitemap, robots, OpenGraph and
# JSON-LD. Set this to your production URL on Vercel.
#   Local:      http://localhost:3000
#   Production: https://valentyn.studio   (custom domain; or your *.vercel.app URL until connected)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Admin credentials
# ADMIN_PASSWORD_HASH is a bcrypt hash — generate it with:  npm run hash-password "yourPassword"
# ---------------------------------------------------------------------------
ADMIN_EMAIL="admin@workflow.dev"
ADMIN_PASSWORD_HASH="$2a$10$replace.with.generated.bcrypt.hash.value.here.0123456789abc"

# ---------------------------------------------------------------------------
# Image uploads (OPTIONAL — signed Cloudinary uploads).
# The site works with plain image URLs out of the box. Set all three values
# (from your Cloudinary Dashboard → Account Details) to enable the Upload
# button in the admin project form. No upload preset needed — uploads are signed.
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
